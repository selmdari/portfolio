---
export interface Props {
  src: string;
  alt?: string;
  poster?: string;
  caption?: string;
  autoRotate?: boolean;
}

const {
  src,
  alt = '3D model',
  poster,
  caption,
  autoRotate = true,
} = Astro.props;
---

<figure class="model-wrap">
  <div class="model-container">
    <model-viewer
      src={src}
      alt={alt}
      poster={poster}
      camera-controls
      auto-rotate={autoRotate}
      auto-rotate-delay="0"
      rotation-per-second="20deg"
      shadow-intensity="0.6"
      environment-image="neutral"
      exposure="0.8"
      loading="lazy"
      reveal="interaction"
    >
      <div class="loading-prompt" slot="progress-bar"></div>
      <div class="interaction-prompt" slot="interaction-prompt"></div>
    </model-viewer>
  </div>
  {caption && <figcaption class="figcaption">{caption}</figcaption>}
</figure>

<script>
  // Load model-viewer only when component is in view
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        if (!customElements.get('model-viewer')) {
          import('https://cdn.jsdelivr.net/npm/@google/model-viewer/dist/model-viewer.min.js');
        }
        observer.disconnect();
      }
    });
  }, { rootMargin: '200px' });

  document.querySelectorAll('model-viewer').forEach(el => observer.observe(el));
</script>

<style>
  .model-wrap {
    margin: 2rem 0;
  }

  .model-container {
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 1px solid var(--border);
    background: var(--bg-sunken);
  }

  model-viewer {
    width: 100%;
    height: 480px;
    --progress-bar-color: rgba(240,237,232,0.2);
    --progress-bar-height: 2px;
  }

  @media (max-width: 700px) {
    model-viewer { height: 320px; }
  }
</style>
