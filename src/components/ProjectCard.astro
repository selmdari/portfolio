---
export interface Props {
  title: string;
  summary: string;
  thumbnail: string;
  date: string;
  disciplines: string[];
  processes: string[];
  tools: string[];
  slug: string;
  featured?: boolean;
}

const { title, summary, thumbnail, date, disciplines, processes, tools, slug, featured } = Astro.props;

function pillClass(discipline: string): string {
  const key = discipline.toLowerCase().replace(/\s+/g, '-');
  const map: Record<string, string> = {
    'hardware': 'hardware',
    'electronics': 'electronics',
    'firmware': 'firmware',
    'robotics': 'robotics',
    'design': 'design',
    'fea': 'fea',
    'structural': 'structural',
    'civil': 'civil',
    'mechanical': 'mechanical',
    'software': 'software',
  };
  return map[key] ?? 'default';
}
---

<a href={import.meta.env.BASE_URL + 'projects/' + slug} class:list={['card', { featured }]}>
  <div class="thumb">
    <img src={import.meta.env.BASE_URL + thumbnail.replace(/^\//, '')} alt={title} loading="lazy" />
    <div class="overlay">
      <p class="overlay-title">{title}</p>
      <div class="pills">
        {disciplines.map(d => (
          <span class={`pill pill-${pillClass(d)}`}>{d}</span>
        ))}
      </div>
      <p class="overlay-meta">
        {processes.slice(0, 3).join(' · ')}
      </p>
      <p class="overlay-tools">
        {tools.slice(0, 4).join(' · ')}
      </p>
    </div>
  </div>
  <div class="card-foot">
    <p class="card-title">{title}</p>
    <p class="card-date">{date}</p>
  </div>
</a>

<style>
  .card {
    display: block;
    border-radius: var(--radius-lg);
    border: 1px solid var(--border);
    background: var(--bg-card);
    transition: border-color var(--transition), transform var(--transition);
    cursor: pointer;
    will-change: transform;
  }

  .card:hover {
    border-color: var(--border-hover);
    transform: translateY(-2px);
  }

  .card.featured {
    border-color: rgba(240,237,232,0.12);
  }

  .thumb {
    position: relative;
    aspect-ratio: 4/3;
    overflow: hidden;
    background: #141414;
    border-radius: var(--radius-lg) var(--radius-lg) 0 0;
  }

  .thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .card:hover .thumb img {
    transform: scale(1.05);
  }

  .overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(0,0,0,0.92) 0%,
      rgba(0,0,0,0.7) 50%,
      rgba(0,0,0,0.2) 100%
    );
    opacity: 0;
    transition: opacity var(--transition);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 1.1rem;
    gap: 6px;
  }

  .card:hover .overlay { opacity: 1; }

  .overlay-title {
    font-size: 0.85rem;
    font-weight: 400;
    color: #fff;
    line-height: 1.3;
    margin: 0;
  }

  .pills {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
  }

  .pill {
    font-size: 0.65rem;
    font-weight: 400;
    padding: 2px 7px;
    border-radius: 99px;
    letter-spacing: 0.03em;
  }

  .pill-hardware    { background: var(--pill-hardware);    color: var(--pill-hardware-text); }
  .pill-electronics { background: var(--pill-electronics); color: var(--pill-electronics-text); }
  .pill-firmware    { background: var(--pill-firmware);    color: var(--pill-firmware-text); }
  .pill-robotics    { background: var(--pill-robotics);    color: var(--pill-robotics-text); }
  .pill-design      { background: var(--pill-design);      color: var(--pill-design-text); }
  .pill-fea         { background: var(--pill-fea);         color: var(--pill-fea-text); }
  .pill-structural  { background: var(--pill-structural);  color: var(--pill-structural-text); }
  .pill-civil       { background: var(--pill-civil);       color: var(--pill-civil-text); }
  .pill-mechanical  { background: var(--pill-mechanical);  color: var(--pill-mechanical-text); }
  .pill-software    { background: var(--pill-software);    color: var(--pill-software-text); }
  .pill-default     { background: var(--pill-default);     color: var(--pill-default-text); }

  .overlay-meta {
    font-size: 0.65rem;
    color: rgba(255,255,255,0.5);
    margin: 0;
    font-family: var(--font-mono);
    font-weight: 300;
  }

  .overlay-tools {
    font-size: 0.62rem;
    color: rgba(255,255,255,0.3);
    margin: 0;
    font-family: var(--font-mono);
    font-weight: 300;
  }

  .card-foot {
    padding: 0.75rem 1rem;
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .card-title {
    font-size: 0.82rem;
    font-weight: 400;
    color: var(--text-primary);
    margin: 0;
    line-height: 1.3;
  }

  .card-date {
    font-size: 0.7rem;
    color: var(--text-tertiary);
    margin: 0;
    white-space: nowrap;
    font-family: var(--font-mono);
    font-weight: 300;
  }
</style>
