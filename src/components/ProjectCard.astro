---
import { pillClass } from '../lib/disciplines';
import { withBase } from '../lib/urls';
import { disciplineLabel, type Lang } from '../lib/i18n';

export interface Props {
  title: string;
  summary: string;
  thumbnail: string;
  date: string;
  disciplines: string[];
  processes: string[];
  tools: string[];
  slug: string;
  featured?: boolean;
  lang?: Lang;
  basePath?: string;
}

const { title, summary, thumbnail, date, disciplines, processes, tools, slug, featured, lang = 'en', basePath = '/projects/' } = Astro.props;
---

<a href={withBase(`${basePath}${slug}`)} class:list={['card', { featured }]}>
  <div class="thumb">
    <img src={withBase(thumbnail)} alt={title} loading="lazy" />
    <div class="overlay">
      <p class="overlay-title">{title}</p>
      <div class="pills">
        {disciplines.map(d => (
          <span class={`pill pill-${pillClass(d)}`}>{disciplineLabel(d, lang)}</span>
        ))}
      </div>
      <p class="overlay-meta">
        {processes.slice(0, 3).join(' · ')}
      </p>
      <p class="overlay-tools">
        {tools.slice(0, 4).join(' · ')}
      </p>
    </div>
  </div>
  <div class="card-foot">
    <p class="card-title">{title}</p>
    <p class="card-date">{date}</p>
  </div>
</a>

<style>
  .card {
    display: block;
    border-radius: var(--radius-lg);
    border: 1px solid var(--border);
    background: var(--bg-card);
    transition: border-color var(--transition), transform var(--transition);
    cursor: pointer;
    will-change: transform;
  }

  .card:hover {
    border-color: var(--border-hover);
    transform: translateY(-2px);
  }

  .card.featured {
    border-color: rgba(240,237,232,0.12);
  }

  .thumb {
    position: relative;
    aspect-ratio: 4/3;
    overflow: hidden;
    background: var(--bg-surface);
    border-radius: var(--radius-lg) var(--radius-lg) 0 0;
  }

  .thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition-slow);
  }

  .card:hover .thumb img {
    transform: scale(1.05);
  }

  .overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(0,0,0,0.92) 0%,
      rgba(0,0,0,0.7) 50%,
      rgba(0,0,0,0.2) 100%
    );
    opacity: 0;
    transition: opacity var(--transition);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 1.65rem;
    gap: 9px;
  }

  .card:hover .overlay { opacity: 1; }

  .overlay-title {
    font-size: 1.1rem;
    font-weight: 400;
    color: #fff;
    line-height: 1.3;
    margin: 0;
  }

  .pills {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
  }

  .overlay-meta {
    font-size: 0.82rem;
    color: rgba(255,255,255,0.5);
    margin: 0;
    font-family: var(--font-mono);
    font-weight: 300;
  }

  .overlay-tools {
    font-size: 0.78rem;
    color: rgba(255,255,255,0.3);
    margin: 0;
    font-family: var(--font-mono);
    font-weight: 300;
  }

  .card-foot {
    padding: 1rem 1.25rem;
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .card-title {
    font-size: 1rem;
    font-weight: 400;
    color: var(--text-primary);
    margin: 0;
    line-height: 1.3;
  }

  .card-date {
    font-size: 0.82rem;
    color: var(--text-tertiary);
    margin: 0;
    white-space: nowrap;
    font-family: var(--font-mono);
    font-weight: 300;
  }
</style>
