---
interface Props {
  splat: string;
  title: string;
  annotations?: { position: [number, number, number]; label: string }[];
  cameraPosition?: [number, number, number];
  minDistance?: number;
  maxDistance?: number;
  modelY?: number;
  orbitAngle?: number;
  lang?: 'en' | 'fr';
}
import { withBase } from '../lib/urls';
import { t } from '../lib/i18n';
const { splat, annotations = [], cameraPosition = [0, 7, 10], minDistance = 0, maxDistance = 25, modelY = 0, orbitAngle = 0, lang = 'en' } = Astro.props;
const splatUrl = withBase(splat);
---

<div class="splat-wrap" data-splat-url={splatUrl} data-camera-position={JSON.stringify(cameraPosition)} data-min-distance={minDistance} data-max-distance={maxDistance} data-model-y={modelY} data-orbit-angle={orbitAngle} data-msg-loading={t(lang, 'splat.loading')} data-msg-hint={t(lang, 'splat.hint')} data-msg-resume={t(lang, 'splat.resume')}>
  <div class="splat-mount"></div>
  <div class="splat-status">{t(lang, 'splat.loading')}</div>
  <div class="splat-hint" hidden>{t(lang, 'splat.hint')}</div>
  <button class="splat-resume" hidden>{t(lang, 'splat.resume')}</button>
  <button class="splat-fs-btn" title="Fullscreen" hidden>⛶</button>
  <div class="splat-overlay">
    {annotations.map((ann, i) => (
      <div
        class="splat-marker"
        data-index={i}
        data-position={JSON.stringify(ann.position)}
        style="display:none"
      >
        <div class="splat-marker-dot"></div>
        <div class="splat-marker-label">{ann.label}</div>
      </div>
    ))}
  </div>
</div>

<script>
  document.querySelectorAll<HTMLElement>('.splat-wrap').forEach((wrap) => {
    const url    = new URL(wrap.dataset.splatUrl!, window.location.origin).href;
    const mount  = wrap.querySelector<HTMLElement>('.splat-mount')!;
    const status = wrap.querySelector<HTMLElement>('.splat-status')!;
    const hint   = wrap.querySelector<HTMLElement>('.splat-hint')!;

    const cameraPosition: [number, number, number] = JSON.parse(wrap.dataset.cameraPosition || '[0,7,10]');
    const minDistance: number = parseFloat(wrap.dataset.minDistance || '0');
    const maxDistance: number = parseFloat(wrap.dataset.maxDistance || '25');
    const modelY: number = parseFloat(wrap.dataset.modelY || '0');
    const orbitAngle: number = parseFloat(wrap.dataset.orbitAngle || '0');

    // Rotate the initial camera position around the Y-axis by orbitAngle degrees
    const θ = orbitAngle * Math.PI / 180;
    const [cx, cy, cz] = cameraPosition;
    const initialCamera: [number, number, number] = [
      cx * Math.cos(θ) + cz * Math.sin(θ),
      cy,
      -cx * Math.sin(θ) + cz * Math.cos(θ),
    ];

    (async () => {
      try {
        const { Viewer, SceneFormat } = await import('@mkkellogg/gaussian-splats-3d');

        // Pre-fetch the splat into a Blob so the library receives the fully
        // decompressed bytes from a blob URL. This avoids the CDN gzip mismatch
        // where Content-Length reports the compressed size but fetch() delivers
        // the larger decompressed payload, causing a buffer overflow in the library.
        const fileResp = await fetch(url);
        if (!fileResp.ok) throw new Error(`HTTP ${fileResp.status} fetching splat`);
        const blobUrl = URL.createObjectURL(await fileResp.blob());

        await new Promise<void>(r => requestAnimationFrame(() => r()));

        const w = mount.clientWidth;
        const ratio = window.innerWidth <= 768 ? 1 : 3 / 4;
        mount.style.height = `${Math.round(w * ratio)}px`;

        const isMobile = window.innerWidth <= 768;
        const viewer = new Viewer({
          selfDrivenMode: true,
          sharedMemoryForWorkers: false,
          gpuAcceleratedSort: false,
          rootElement: mount,
          initialCameraPosition: initialCamera,
          ...(isMobile ? {} : {
            antialiased: true,
          }),
        });

        await viewer.addSplatScene(blobUrl, {
          splatAlphaRemovalThreshold: 1,
          showLoadingUI: false,
          position: [0, modelY, 0],
          rotation: [0, 0, 1, 0],
          format: SceneFormat.Splat,
        });

        URL.revokeObjectURL(blobUrl);

        status.textContent = '';
        hint.textContent = wrap.dataset.msgHint!;
        hint.removeAttribute('hidden');

        const controls = (viewer as any).controls;
        if (controls) {
          // Orbit: top view down to 75° from vertical
          controls.maxPolarAngle = 75 * Math.PI / 180;
          // Zoom: clamp how close and how far the user can go
          controls.minDistance = minDistance;
          controls.maxDistance = maxDistance;

          // Slow auto-orbit; stops the moment the user grabs the scene
          controls.autoRotate = true;
          controls.autoRotateSpeed = 1.0;
          mount.addEventListener('pointerdown', () => {
            controls.autoRotate = false;
            hint.style.opacity = '0';
          }, { once: true });
        }

        viewer.start();

        // ── Mobile: pause render loop when scrolled away, resume on tap ──
        if (window.innerWidth <= 768) {
          const resumeBtn = wrap.querySelector<HTMLElement>('.splat-resume');
          let stopped = false;

          new IntersectionObserver(entries => {
            if (!entries[0].isIntersecting && !stopped) {
              viewer.stop();
              stopped = true;
              resumeBtn!.hidden = false;
            }
          }, { threshold: 0.1 }).observe(wrap);

          resumeBtn!.addEventListener('click', () => {
            viewer.start();
            stopped = false;
            resumeBtn!.hidden = true;
          });
        }

        // ── Desktop: fullscreen (same model, resize mount to fill screen) ──
        const canHover = window.matchMedia('(hover: hover) and (pointer: fine)').matches;

        if (canHover) {
          const fsBtn = wrap.querySelector<HTMLElement>('.splat-fs-btn')!;
          const normalHeight = mount.style.height;

          fsBtn.hidden = false;
          fsBtn.addEventListener('click', () => {
            if (document.fullscreenElement === wrap) document.exitFullscreen();
            else wrap.requestFullscreen();
          });

          document.addEventListener('fullscreenchange', () => {
            if (document.fullscreenElement === wrap) {
              mount.style.height = `${window.innerHeight}px`;
            } else {
              mount.style.height = normalHeight;
            }
            window.dispatchEvent(new Event('resize'));
          });
        }

        // ── Tooltip marker projection (desktop/hover-capable devices only) ──
        const markerEls = canHover ? [...wrap.querySelectorAll<HTMLElement>('.splat-marker')] : [];
        if (markerEls.length) {
          const markerData = markerEls.map(el => ({
            el,
            pos: JSON.parse(el.dataset.position!) as [number, number, number],
          }));

          // Project a world-space point to screen coords using the camera's
          // matrices directly — no separate Three.js import needed.
          function projectPoint(x: number, y: number, z: number, camera: any, W: number, H: number) {
            const me = camera.matrixWorldInverse.elements;
            const vx = me[0]*x + me[4]*y + me[8]*z  + me[12];
            const vy = me[1]*x + me[5]*y + me[9]*z  + me[13];
            const vz = me[2]*x + me[6]*y + me[10]*z + me[14];
            const vw = me[3]*x + me[7]*y + me[11]*z + me[15];
            const pe = camera.projectionMatrix.elements;
            const cx = pe[0]*vx + pe[4]*vy + pe[8]*vz  + pe[12]*vw;
            const cy = pe[1]*vx + pe[5]*vy + pe[9]*vz  + pe[13]*vw;
            const cz = pe[2]*vx + pe[6]*vy + pe[10]*vz + pe[14]*vw;
            const cw = pe[3]*vx + pe[7]*vy + pe[11]*vz + pe[15]*vw;
            return {
              sx: (cx/cw + 1) / 2 * W,
              sy: (1 - cy/cw) / 2 * H,
              behind: (cz/cw) > 1,
            };
          }

          function projectMarkers() {
            const camera = (viewer as any).camera;
            if (!camera) { requestAnimationFrame(projectMarkers); return; }

            const W = mount.clientWidth;
            const H = mount.clientHeight;

            for (const { el, pos } of markerData) {
              const { sx, sy, behind } = projectPoint(pos[0], pos[1] + modelY, pos[2], camera, W, H);
              if (behind) {
                el.style.display = 'none';
              } else {
                el.style.display = '';
                el.style.transform = `translate(${sx - 10}px, ${sy - 10}px)`;
              }
            }
            requestAnimationFrame(projectMarkers);
          }
          projectMarkers();
        }

        // Signal to dev-splat-tool if present
        mount.dispatchEvent(new CustomEvent('splat:ready', {
          detail: { viewer },
          bubbles: true,
        }));

      } catch (err) {
        const msg = err instanceof Error ? err.message : String(err);
        status.textContent = `3D scan failed to load: ${msg}`;
        console.error('[SplatHero]', err);
      }
    })();
  });
</script>

<style>
  .splat-wrap {
    position: relative;
    width: 100%;
    background: var(--bg);
  }

  .splat-mount {
    width: 100%;
    /* height driven by JS */
  }

  .splat-mount :global(canvas) {
    display: block;
  }

  .splat-status {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-size: 0.78rem;
    color: var(--text-tertiary);
    font-family: var(--font-mono);
    pointer-events: none;
    white-space: nowrap;
  }

  .splat-hint {
    position: absolute;
    top: 1rem;
    left: 50%;
    transform: translateX(-50%);
    font-size: 0.7rem;
    color: var(--text-tertiary);
    font-family: var(--font-mono);
    pointer-events: none;
    white-space: nowrap;
    opacity: 1;
    transition: opacity 0.4s ease;
  }

  .splat-hint[hidden] {
    display: none;
  }

  .splat-resume {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    background: rgba(14, 14, 14, 0.85);
    border: 1px solid var(--border-hover);
    color: var(--text-primary);
    font-family: var(--font-mono);
    font-size: 0.82rem;
    padding: 8px 18px;
    border-radius: var(--radius-sm);
    cursor: pointer;
    letter-spacing: 0.04em;
    white-space: nowrap;
  }

  /* ── Fullscreen button ───────────────────────────────────────────────── */
  .splat-fs-btn {
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
    background: rgba(14, 14, 14, 0.7);
    border: 1px solid var(--border-hover);
    color: var(--text-primary);
    font-size: 1rem;
    width: 32px;
    height: 32px;
    border-radius: var(--radius-sm);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background var(--transition);
    z-index: 2;
  }

  .splat-fs-btn[hidden] { display: none; }

  .splat-fs-btn:hover {
    background: rgba(14, 14, 14, 0.95);
  }

  /* ── Tooltip markers ─────────────────────────────────────────────────── */
  .splat-overlay {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
  }

  .splat-marker {
    position: absolute;
    top: 0;
    left: 0;
    pointer-events: auto;
  }

  .splat-marker-dot {
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background: rgba(232, 224, 208, 0.12);
    border: 1.5px solid rgba(232, 224, 208, 0.75);
    animation: splat-pulse 2.5s ease-in-out infinite;
    cursor: default;
    transition: transform var(--transition), background var(--transition), border-color var(--transition);
  }

  .splat-marker:hover .splat-marker-dot {
    transform: scale(1.8);
    background: rgba(232, 224, 208, 0.28);
    border-color: rgba(232, 224, 208, 1);
    animation-play-state: paused;
  }

  .splat-marker-label {
    position: absolute;
    bottom: calc(100% + 10px);
    left: 50%;
    transform: translateX(-50%);
    background: rgba(14, 14, 14, 0.92);
    border: 1px solid var(--border-hover);
    color: var(--text-primary);
    font-family: var(--font-mono);
    font-size: 0.82rem;
    padding: 6px 12px;
    border-radius: var(--radius-sm);
    white-space: nowrap;
    opacity: 0;
    transition: opacity var(--transition);
    pointer-events: none;
    letter-spacing: 0.02em;
  }

  .splat-marker:hover .splat-marker-label {
    opacity: 1;
  }

  @keyframes splat-pulse {
    0%   { box-shadow: 0 0 0 0   rgba(232, 224, 208, 0.5); }
    60%  { box-shadow: 0 0 0 9px rgba(232, 224, 208, 0);   }
    100% { box-shadow: 0 0 0 0   rgba(232, 224, 208, 0);   }
  }
</style>
