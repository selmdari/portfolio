---
interface Props {
  label?: string;
}
const { label = 'TLDR' } = Astro.props;
---
<div class="at-a-glance">
  <span class="label">{label}</span>
  <div class="content">
    <slot />
  </div>
</div>

<style>
  .at-a-glance {
    background: var(--bg-elevated);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: var(--radius-lg);
    padding: 1.5rem 1.75rem;
    margin: 2rem 0 2.75rem;
  }

  .label {
    display: block;
    font-size: 1.6rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-fade-28);
    margin-bottom: 0.5rem;
    font-family: var(--font-mono);
    font-weight: bold;
  }

  .content :global(p) {
    font-size: 1.2rem;
    line-height: 1.6;
    color: var(--text-fade-60);
    margin: 0;
    font-weight: 300;
  }

  .content :global(p + p) {
    margin-top: 0.75rem;
  }
</style>
