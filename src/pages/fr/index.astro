---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import ProjectCard from '../../components/ProjectCard.astro';

const allProjects = await getCollection('fr');
const sorted = allProjects.sort((a, b) =>
  new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
const featured = sorted.filter(p => p.data.featured);
const nonFeatured = sorted.filter(p => !p.data.featured);
---

<Base title="Soufiane El Mdari — Portfolio Ingénierie" lang="fr" localePath="/">
  <section class="hero">
    <h1>Portfolio Ingénierie</h1>
    <p class="about">Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris nisi ut aliquip ex ea commodo.</p>
  </section>

  <div class="grid grid-featured">
    {featured.map(project => (
      <ProjectCard
        title={project.data.title}
        summary={project.data.summary}
        thumbnail={project.data.thumbnail}
        date={project.data.date}
        disciplines={project.data.disciplines}
        processes={project.data.processes}
        tools={project.data.tools}
        slug={project.id}
        featured={project.data.featured}
        lang="fr"
        basePath="/fr/projects/"
      />
    ))}
  </div>
  {nonFeatured.length > 0 && (
    <div class="grid grid-secondary">
      {nonFeatured.map(project => (
        <ProjectCard
          title={project.data.title}
          summary={project.data.summary}
          thumbnail={project.data.thumbnail}
          date={project.data.date}
          disciplines={project.data.disciplines}
          processes={project.data.processes}
          tools={project.data.tools}
          slug={project.id}
          featured={project.data.featured}
          lang="fr"
          basePath="/fr/projects/"
        />
      ))}
    </div>
  )}
</Base>

<style>
  .hero {
    margin-bottom: 3rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--border);
  }

  .hero h1 {
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    font-weight: 300;
    color: var(--text-primary);
    letter-spacing: -0.03em;
    margin-bottom: 0.4rem;
  }

  .about {
    font-size: 0.95rem;
    color: var(--text-secondary);
    line-height: 1.6;
    font-weight: 300;
    margin: 0;
    max-width: 60ch;
  }

  .grid {
    display: grid;
    gap: 1.75rem;
  }

  .grid-featured {
    grid-template-columns: repeat(2, 1fr);
  }

  .grid-secondary {
    grid-template-columns: repeat(3, 1fr);
    margin-top: 1.75rem;
  }

  @media (max-width: 900px) {
    .grid-secondary { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 700px) {
    .grid-featured,
    .grid-secondary { grid-template-columns: 1fr; }
  }
</style>
