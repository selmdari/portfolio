---
import { getCollection, render } from 'astro:content';
import Base from '../../../layouts/Base.astro';
import MdxImage from '../../../components/MdxImage.astro';
import SplatHero from '../../../components/SplatHero.astro';
import TableOfContents from '../../../components/TableOfContents.astro';
import { pillClass } from '../../../lib/disciplines';
import { withBase } from '../../../lib/urls';
import { disciplineLabel } from '../../../lib/i18n';

export async function getStaticPaths() {
  const projects = await getCollection('fr');
  return projects.map(project => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content, headings } = await render(project);
const { title, summary, thumbnail, date, disciplines, splat, splatPly, showToc, splatAnnotations, splatCameraPosition, splatMinDistance, splatMaxDistance, splatModelY, splatOrbitAngle } = project.data;
const showTocSidebar = showToc && headings.length > 0;
---

<Base title={`${title} — Soufiane El Mdari`} description={summary} lang="fr" localePath={`/projects/${project.id}`}>
  <article>
    <header class="project-header">
      {!showTocSidebar && (
        <a href={withBase('/fr/')} class="back-link">← Tous les projets</a>
      )}

      <h1>{title}</h1>

      <div class="meta-row">
        <div class="pills">
          {disciplines.map(d => (
            <span class={`pill pill-${pillClass(d)}`}>{disciplineLabel(d, 'fr')}</span>
          ))}
        </div>
        <span class="meta-date">{date}</span>
      </div>

      <div class="hero-image">
        {splat
          ? <SplatHero splat={splat} splatPly={splatPly} title={title} annotations={splatAnnotations} cameraPosition={splatCameraPosition} minDistance={splatMinDistance} maxDistance={splatMaxDistance} modelY={splatModelY} orbitAngle={splatOrbitAngle} lang="fr" />
          : <img src={withBase(thumbnail)} alt={title} />
        }
      </div>
    </header>

    {showTocSidebar ? (
      <div class="content-layout">
        <div class="prose">
          <Content components={{ img: MdxImage }} />
        </div>
        <aside class="toc-aside" id="toc-aside">
          <TableOfContents headings={headings} lang="fr" />
        </aside>
      </div>
    ) : (
      <div class="prose prose-solo">
        <Content components={{ img: MdxImage }} />
      </div>
    )}
  </article>
</Base>

{showTocSidebar && (
  <script>
    import '../../../scripts/toc-mobile';
  </script>
)}

<style>
  article {
    width: 100%;
  }

  .project-header {
    margin-bottom: 3.5rem;
  }

  .back-link {
    display: inline-block;
    font-size: 0.78rem;
    color: var(--text-tertiary);
    margin-bottom: 2rem;
    transition: color var(--transition);
    letter-spacing: 0.02em;
  }

  .back-link:hover { color: var(--text-primary); }

  h1 {
    font-size: clamp(1.6rem, 3.5vw, 2.4rem);
    font-weight: 300;
    color: var(--text-primary);
    letter-spacing: -0.03em;
    margin-bottom: 0.75rem;
  }

  .project-summary {
    font-size: 1.5rem;
    color: var(--text-secondary);
    line-height: 1.65;
    margin-bottom: 1.5rem;
    font-weight: 300;
  }

  .meta-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1.25rem;
    flex-wrap: wrap;
  }

  .pills {
    display: flex;
    flex-wrap: wrap;
    gap: 5px;
  }

  .pill {
    font-size: 0.68rem;
    padding: 3px 9px;
  }

  .meta-date {
    font-size: 0.75rem;
    color: var(--text-tertiary);
    font-family: var(--font-mono);
    font-weight: 300;
    white-space: nowrap;
  }

  .hero-image {
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 1px solid var(--border);
  }

  .hero-image img {
    width: 100%;
    display: block;
  }

  .content-layout {
    display: flex;
    flex-direction: row;
    align-items: flex-start;
    gap: 3rem;
  }

  .prose {
    flex: 1;
    min-width: 0;
  }

  .toc-aside {
    width: 200px;
    flex-shrink: 0;
    position: sticky;
    top: calc(56px + 2rem);
  }

  .prose-solo {
    width: 100%;
  }

  @media (max-width: 700px) {
    .content-layout {
      flex-direction: column;
    }

    .toc-aside {
      width: 100%;
      position: static;
    }
  }

  .prose :global(h2),
  .prose-solo :global(h2) {
    font-size: 1.9rem;
    font-weight: 400;
    color: var(--text-primary);
    margin: 3rem 0 0.75rem;
    letter-spacing: -0.02em;
  }

  .prose :global(h3),
  .prose-solo :global(h3) {
    font-size: 1.3rem;
    font-weight: 400;
    color: var(--text-primary);
    margin: 2.5rem 0 0.5rem;
  }

  .prose :global(p),
  .prose-solo :global(p) {
    font-size: 1.1rem;
    line-height: 1.8;
    font-weight: 300;
    margin-bottom: 1.25rem;
    color: var(--text-secondary);
  }

  .prose :global(em),
  .prose-solo :global(em) {
    color: var(--text-tertiary);
    font-style: italic;
  }

  .prose :global(strong),
  .prose-solo :global(strong) {
    color: var(--text-primary);
    font-weight: 400;
  }

  .prose :global(img),
  .prose-solo :global(img) {
    width: 100%;
    border-radius: var(--radius-md);
    border: 1px solid var(--border);
    margin: 1.5rem 0;
  }

  .prose :global(video),
  .prose-solo :global(video) {
    width: 100%;
    border-radius: var(--radius-md);
    border: 1px solid var(--border);
    margin: 1.5rem 0;
  }

  .prose :global(ul),
  .prose :global(ol),
  .prose-solo :global(ul),
  .prose-solo :global(ol) {
    padding-left: 1.25rem;
    margin-bottom: 1.25rem;
    font-size: 0.95rem;
    line-height: 1.8;
    font-weight: 300;
    color: var(--text-secondary);
  }

  .prose :global(li),
  .prose-solo :global(li) {
    margin-bottom: 0.35rem;
    color: var(--text-secondary);
  }

  .prose :global(code),
  .prose-solo :global(code) {
    font-family: var(--font-mono);
    font-size: 0.82em;
    background: var(--bg-card);
    padding: 0.15em 0.4em;
    border-radius: var(--radius-sm);
    color: var(--text-primary);
    border: 1px solid var(--border);
  }

  .prose :global(blockquote),
  .prose-solo :global(blockquote) {
    border-left: 2px solid var(--border-hover);
    padding-left: 1.25rem;
    margin: 1.5rem 0;
    color: var(--text-tertiary);
    font-style: italic;
  }
</style>
