---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import ProjectCard from '../components/ProjectCard.astro';

const allProjects = await getCollection('projects');
const projects = allProjects.sort((a, b) =>
  new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
---

<Base title="Soufiane El Mdari — Engineering Portfolio">
  <section class="hero">
    <h1>Engineering Portfolio</h1>
    <p class="hero-sub">Design · Hardware · Electronics · Firmware</p>
  </section>

  <div class="grid" id="project-grid">
    {projects.map(project => (
      <ProjectCard
        title={project.data.title}
        summary={project.data.summary}
        thumbnail={project.data.thumbnail}
        date={project.data.date}
        disciplines={project.data.disciplines}
        processes={project.data.processes}
        tools={project.data.tools}
        slug={project.id}
        featured={project.data.featured}
      />
    ))}
  </div>
</Base>

<style>
  .hero {
    margin-bottom: 3rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--border);
  }

  .hero h1 {
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    font-weight: 300;
    color: var(--text-primary);
    letter-spacing: -0.03em;
    margin-bottom: 0.4rem;
  }

  .hero-sub {
    font-size: 0.9rem;
    color: var(--text-tertiary);
    letter-spacing: 0.08em;
    font-weight: 300;
    margin: 0;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.75rem;
  }

  @media (max-width: 700px) {
    .grid { grid-template-columns: 1fr; }
  }
</style>
