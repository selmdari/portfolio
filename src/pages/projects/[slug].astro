---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import MdxImage from '../../components/MdxImage.astro';
import SplatHero from '../../components/SplatHero.astro';
import TableOfContents from '../../components/TableOfContents.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map(project => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content, headings } = await render(project);
const { title, summary, thumbnail, date, disciplines, splat, showToc, splatAnnotations, splatCameraPosition, splatMinDistance, splatMaxDistance, splatModelY, splatOrbitAngle } = project.data;

function pillClass(discipline: string): string {
  const key = discipline.toLowerCase().replace(/\s+/g, '-');
  const map: Record<string, string> = {
    'hardware': 'hardware', 'electronics': 'electronics',
    'firmware': 'firmware', 'robotics': 'robotics',
    'design': 'design', 'fea': 'fea', 'structural': 'structural',
    'civil': 'civil', 'mechanical': 'mechanical', 'software': 'software',
  };
  return map[key] ?? 'default';
}
---

<Base title={`${title} — Soufiane El Mdari`} description={summary}>
  <article>
    <header class="project-header">
      {!showToc && (
        <a href={import.meta.env.BASE_URL} class="back-link">← All projects</a>
      )}

      <h1>{title}</h1>
      <p class="project-summary">{summary}</p>

      <div class="meta-row">
        <div class="pills">
          {disciplines.map(d => (
            <span class={`pill pill-${pillClass(d)}`}>{d}</span>
          ))}
        </div>
        <span class="meta-date">{date}</span>
      </div>

      <div class="hero-image">
        {splat
          ? <SplatHero splat={splat} title={title} annotations={splatAnnotations} cameraPosition={splatCameraPosition} minDistance={splatMinDistance} maxDistance={splatMaxDistance} modelY={splatModelY} orbitAngle={splatOrbitAngle} />
          : <img src={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/${thumbnail.replace(/^\//, '')}`} alt={title} />
        }
      </div>
    </header>

    {showToc ? (
      <div class="content-layout">
        <div class="prose">
          <Content components={{ img: MdxImage }} />
        </div>
        <aside class="toc-aside" id="toc-aside">
          <TableOfContents headings={headings} />
        </aside>
      </div>
    ) : (
      <div class="prose prose-solo">
        <Content components={{ img: MdxImage }} />
      </div>
    )}
  </article>
</Base>

{showToc && (
  <script is:inline>
    // On mobile, move the TOC to appear right after the At A Glance box.
    // On desktop it lives inside .content-layout as a flex sibling of .prose.
    (function () {
      const mq = window.matchMedia('(max-width: 767px)');

      function positionToc() {
        const toc = document.getElementById('toc-aside');
        const atAGlance = document.querySelector('.at-a-glance');
        const contentLayout = document.querySelector('.content-layout');
        if (!toc || !atAGlance || !contentLayout) return;

        if (mq.matches) {
          // Insert immediately after .at-a-glance (inside .prose)
          atAGlance.insertAdjacentElement('afterend', toc);
        } else {
          // Return to .content-layout as the second flex child
          if (toc.parentElement !== contentLayout) {
            contentLayout.appendChild(toc);
          }
        }
      }

      positionToc();
      mq.addEventListener('change', positionToc);
    })();
  </script>
)}

<style>
  /* ── Article shell ─────────────────────────────────────────────────────── */
  /* Base.astro's <main> already provides max-width: 1200px + margin: 0 auto.
     The article fills that container; the two-column layout centers itself. */
  article {
    width: 100%;
  }

  /* ── Project header ────────────────────────────────────────────────────── */
  .project-header {
    margin-bottom: 3.5rem;
  }

  .back-link {
    display: inline-block;
    font-size: 0.78rem;
    color: var(--text-tertiary);
    margin-bottom: 2rem;
    transition: color var(--transition);
    letter-spacing: 0.02em;
  }

  .back-link:hover { color: var(--text-primary); }

  h1 {
    font-size: clamp(1.6rem, 3.5vw, 2.4rem);
    font-weight: 300;
    color: var(--text-primary);
    letter-spacing: -0.03em;
    margin-bottom: 0.75rem;
  }

  .project-summary {
    font-size: 1rem;
    color: var(--text-secondary);
    line-height: 1.65;
    margin-bottom: 1.5rem;
    font-weight: 300;
  }

  .meta-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1.25rem;
    flex-wrap: wrap;
  }

  .pills {
    display: flex;
    flex-wrap: wrap;
    gap: 5px;
  }

  .pill {
    font-size: 0.68rem;
    font-weight: 400;
    padding: 3px 9px;
    border-radius: 99px;
    letter-spacing: 0.03em;
  }

  .pill-hardware    { background: var(--pill-hardware);    color: var(--pill-hardware-text); }
  .pill-electronics { background: var(--pill-electronics); color: var(--pill-electronics-text); }
  .pill-firmware    { background: var(--pill-firmware);    color: var(--pill-firmware-text); }
  .pill-robotics    { background: var(--pill-robotics);    color: var(--pill-robotics-text); }
  .pill-design      { background: var(--pill-design);      color: var(--pill-design-text); }
  .pill-fea         { background: var(--pill-fea);         color: var(--pill-fea-text); }
  .pill-structural  { background: var(--pill-structural);  color: var(--pill-structural-text); }
  .pill-civil       { background: var(--pill-civil);       color: var(--pill-civil-text); }
  .pill-mechanical  { background: var(--pill-mechanical);  color: var(--pill-mechanical-text); }
  .pill-software    { background: var(--pill-software);    color: var(--pill-software-text); }
  .pill-default     { background: var(--pill-default);     color: var(--pill-default-text); }

  .meta-date {
    font-size: 0.75rem;
    color: var(--text-tertiary);
    font-family: var(--font-mono);
    font-weight: 300;
    white-space: nowrap;
  }

  .hero-image {
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 1px solid var(--border);
  }

  .hero-image img {
    width: 100%;
    max-height: 520px;
    object-fit: cover;
  }

  /* ── Two-column layout (with TOC) ──────────────────────────────────────── */
  .content-layout {
    display: flex;
    flex-direction: row;
    align-items: flex-start; /* lets sticky TOC stop at article end */
    gap: 3rem;
  }

  .prose {
    flex: 1;
    min-width: 0; /* prevents flex overflow */
  }

  .toc-aside {
    width: 200px;
    flex-shrink: 0;
    position: sticky;
    top: calc(56px + 2rem); /* header height + breathing room */
  }

  /* ── Prose-only layout (no TOC) ────────────────────────────────────────── */
  .prose-solo {
    max-width: 780px;
    margin: 0 auto;
  }

  /* ── Mobile ─────────────────────────────────────────────────────────────── */
  @media (max-width: 767px) {
    .content-layout {
      flex-direction: column;
    }

    /* TOC is moved by JS to appear after .at-a-glance;
       reset sticky and width so it flows as a block. */
    .toc-aside {
      width: 100%;
      position: static;
    }
  }

  /* ── Prose styles ───────────────────────────────────────────────────────── */
  .prose :global(h2),
  .prose-solo :global(h2) {
    font-size: 1.2rem;
    font-weight: 400;
    color: var(--text-primary);
    margin: 2.5rem 0 0.75rem;
    letter-spacing: -0.02em;
  }

  .prose :global(h3),
  .prose-solo :global(h3) {
    font-size: 1rem;
    font-weight: 400;
    color: var(--text-primary);
    margin: 2rem 0 0.5rem;
  }

  .prose :global(p),
  .prose-solo :global(p) {
    font-size: 0.95rem;
    line-height: 1.8;
    font-weight: 300;
    margin-bottom: 1.25rem;
    color: var(--text-secondary);
  }

  .prose :global(em),
  .prose-solo :global(em) {
    color: var(--text-tertiary);
    font-style: italic;
  }

  .prose :global(strong),
  .prose-solo :global(strong) {
    color: var(--text-primary);
    font-weight: 400;
  }

  .prose :global(img),
  .prose-solo :global(img) {
    width: 100%;
    border-radius: var(--radius-md);
    border: 1px solid var(--border);
    margin: 1.5rem 0;
  }

  .prose :global(video),
  .prose-solo :global(video) {
    width: 100%;
    border-radius: var(--radius-md);
    border: 1px solid var(--border);
    margin: 1.5rem 0;
  }

  .prose :global(ul),
  .prose :global(ol),
  .prose-solo :global(ul),
  .prose-solo :global(ol) {
    padding-left: 1.25rem;
    margin-bottom: 1.25rem;
    font-size: 0.95rem;
    line-height: 1.8;
    font-weight: 300;
    color: var(--text-secondary);
  }

  .prose :global(li),
  .prose-solo :global(li) {
    margin-bottom: 0.35rem;
    color: var(--text-secondary);
  }

  .prose :global(code),
  .prose-solo :global(code) {
    font-family: var(--font-mono);
    font-size: 0.82em;
    background: var(--bg-card);
    padding: 0.15em 0.4em;
    border-radius: var(--radius-sm);
    color: var(--text-primary);
    border: 1px solid var(--border);
  }

  .prose :global(blockquote),
  .prose-solo :global(blockquote) {
    border-left: 2px solid var(--border-hover);
    padding-left: 1.25rem;
    margin: 1.5rem 0;
    color: var(--text-tertiary);
    font-style: italic;
  }
</style>
