---
import '../styles/global.css';
import { withBase } from '../lib/urls';

export interface Props {
  title?: string;
  description?: string;
  lang?: 'en' | 'fr';
  localePath?: string;
}

const {
  title = 'Soufiane El Mdari',
  description = 'Engineering Portfolio',
  lang = 'en',
  localePath,
} = Astro.props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href={withBase('/favicon.svg')} />
    {!import.meta.env.DEV && <script is:inline src="/portfolio/coi-serviceworker.js"></script>}
  </head>
  <body>
    <header>
      <nav>
        <a href={withBase(lang === 'fr' ? '/fr/' : '/')} class="nav-name">Soufiane El Mdari</a>
        {localePath && (
          <a href={withBase(localePath)} class="lang-switch">{lang === 'en' ? 'FR' : 'EN'}</a>
        )}
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer>
      <span>© {new Date().getFullYear()} Soufiane El Mdari</span>
    </footer>
  </body>
</html>

<style>
  header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(10,10,10,0.85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
  }

  nav {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
    height: 56px;
    display: flex;
    align-items: center;
    gap: 1.25rem;
  }

  .nav-name {
    font-size: 1.2rem;
    font-weight: 400;
    letter-spacing: 0.01em;
    color: var(--text-primary);
    transition: opacity var(--transition);
  }

  .nav-name:hover { opacity: 0.6; }

  .lang-switch {
    margin-left: auto;
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    color: var(--text-secondary);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 0.25rem 0.55rem;
    background: rgba(255,255,255,0.04);
    transition: color var(--transition), border-color var(--transition), background var(--transition);
  }

  .lang-switch:hover {
    color: var(--text-primary);
    border-color: var(--text-tertiary);
    background: rgba(255,255,255,0.08);
  }

  .nav-descriptor {
    font-size: 0.75rem;
    color: var(--text-tertiary);
    font-weight: 300;
    letter-spacing: 0.05em;
  }

  main {
    max-width: 1200px;
    margin: 0 auto;
    padding: 3rem 2rem 6rem;
  }

  footer {
    border-top: 1px solid var(--border);
    padding: 1.5rem 2rem;
    text-align: center;
    font-size: 0.75rem;
    color: var(--text-tertiary);
    font-weight: 300;
  }
</style>
